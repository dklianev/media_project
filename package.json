{
  "name": "media-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "deploy": "bash scripts/deploy.sh",
    "build": "vite build",
    "start": "node server/index.js",
