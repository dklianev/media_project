# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
EMBED_TOKEN_SECRET=your-embed-token-secret-change-this
STREAM_TOKEN_TTL=8h
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/auth
REFRESH_COOKIE_SAME_SITE=lax
# Ако е none, secure е задължително true
# REFRESH_COOKIE_SECURE=true
# REFRESH_COOKIE_DOMAIN=.example.com
# DB_PATH=./data/media.db

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback

# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:5173
# Optional: Vite dev proxy target. Use 127.0.0.1 to avoid localhost IPv6 issues.
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# API performance/rate limits
JSON_LIMIT=1mb
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=40
TRUST_PROXY=1
UPLOAD_MAX_FILE_SIZE_MB=10
VIDEO_MAX_FILE_SIZE_MB=12288
SERVER_REQUEST_TIMEOUT_MS=3600000
SERVER_HEADERS_TIMEOUT_MS=3660000
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
DEV_PROXY_TIMEOUT_MS=3600000
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_WEBP_QUALITY=82

# First superadmin Discord ID (will be auto-promoted)
ADMIN_DISCORD_ID=your-discord-id
